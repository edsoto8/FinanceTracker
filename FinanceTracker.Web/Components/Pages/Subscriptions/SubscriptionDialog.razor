@inject ISubscriptionService SubscriptionService
@inject ICategoryService CategoryService
@inject IAccountService AccountService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Model.Name" Label="Name" Required="true" MaxLength="100" />
        <MudNumericField @bind-Value="Model.Cost" Label="Cost" Format="N2" Min="0" Class="mt-3" />
        <MudSelect @bind-Value="Model.Frequency" Label="Frequency" Class="mt-3">
            @foreach (BillingFrequency freq in Enum.GetValues<BillingFrequency>())
            {
                <MudSelectItem Value="freq">@freq</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker @bind-Date="_nextBillingDate" Label="Next Billing Date" Class="mt-3" />
        <MudSelect @bind-Value="Model.CategoryId" Label="Category" Class="mt-3">
            @foreach (var category in _categories)
            {
                <MudSelectItem T="int" Value="category.Id">@category.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="int?" @bind-Value="Model.AccountId" Label="Payment Account (optional)" Clearable="true" Class="mt-3">
            @foreach (var account in _accounts)
            {
                <MudSelectItem T="int?" Value="account.Id">@account.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="Model.Notes" Label="Notes" Lines="2" MaxLength="500" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Subscription Model { get; set; } = new();

    private List<Category> _categories = new();
    private List<Account> _accounts = new();
    private DateTime? _nextBillingDate;

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetAllAsync()).ToList();
        _accounts = (await AccountService.GetActiveAccountsAsync()).ToList();
        _nextBillingDate = Model.NextBillingDate == default ? DateTime.Today : Model.NextBillingDate;
        if (Model.CategoryId == 0 && _categories.Count > 0)
        {
            Model.CategoryId = _categories[0].Id;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            Snackbar.Add("Name is required", Severity.Error);
            return;
        }

        if (Model.Cost <= 0)
        {
            Snackbar.Add("Cost must be greater than zero", Severity.Error);
            return;
        }

        Model.NextBillingDate = _nextBillingDate ?? DateTime.Today;

        if (Model.Id == 0)
        {
            await SubscriptionService.AddAsync(Model);
            Snackbar.Add("Subscription added", Severity.Success);
        }
        else
        {
            await SubscriptionService.UpdateAsync(Model);
            Snackbar.Add("Subscription updated", Severity.Success);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
