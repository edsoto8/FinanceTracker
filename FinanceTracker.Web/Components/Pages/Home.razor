@page "/"
@using FinanceTracker.Core.Models
@using FinanceTracker.Core.Services
@inject AccountService AccountService
@inject ExpenseService ExpenseService
@inject SubscriptionService SubscriptionService
@inject DocumentService DocumentService
@rendermode InteractiveServer

<PageTitle>Dashboard - Finance Tracker</PageTitle>

<h1>Dashboard</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <h6 class="card-subtitle mb-1 text-muted">Total Balance</h6>
                    <h3 class="card-title text-primary">@_totalBalance.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body">
                    <h6 class="card-subtitle mb-1 text-muted">Monthly Spending</h6>
                    <h3 class="card-title text-danger">@_monthlySpending.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body">
                    <h6 class="card-subtitle mb-1 text-muted">Monthly Subscriptions</h6>
                    <h3 class="card-title text-warning">@_monthlySubscriptions.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body">
                    <h6 class="card-subtitle mb-1 text-muted">Active Accounts</h6>
                    <h3 class="card-title text-info">@_activeAccountCount</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Upcoming Subscriptions (30 days)</span>
                    <a href="/subscriptions" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (!_upcomingSubscriptions.Any())
                    {
                        <p class="p-3 text-muted">None upcoming.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Name</th><th>Due</th><th class="text-end">Cost</th></tr></thead>
                            <tbody>
                            @foreach (var s in _upcomingSubscriptions)
                            {
                                <tr>
                                    <td>@s.Name</td>
                                    <td>@s.NextBillingDate.ToString("MMM d")</td>
                                    <td class="text-end">@s.Cost.ToString("C")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Documents Expiring Soon (30 days)</span>
                    <a href="/documents" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (!_expiringDocuments.Any())
                    {
                        <p class="p-3 text-muted">None expiring soon.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Document</th><th>Type</th><th>Expires</th></tr></thead>
                            <tbody>
                            @foreach (var d in _expiringDocuments)
                            {
                                <tr>
                                    <td>@d.Name</td>
                                    <td>@d.Type</td>
                                    <td class="@(d.ExpirationDate < DateTime.Now.AddDays(7) ? "text-danger fw-bold" : "")">
                                        @d.ExpirationDate.ToString("MMM d, yyyy")
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Recent Expenses</span>
                    <a href="/expenses" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (!_recentExpenses.Any())
                    {
                        <p class="p-3 text-muted">No recent expenses.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Date</th><th>Description</th><th>Category</th><th class="text-end">Amount</th></tr></thead>
                            <tbody>
                            @foreach (var e in _recentExpenses)
                            {
                                <tr>
                                    <td>@e.TransactionDate.ToString("MMM d")</td>
                                    <td>@e.Description</td>
                                    <td>@e.Category</td>
                                    <td class="text-end">@e.Amount.ToString("C")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between">
                    <span>Account Summary</span>
                    <a href="/accounts" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (!_accounts.Any())
                    {
                        <p class="p-3 text-muted">No accounts yet.</p>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Account</th><th>Institution</th><th>Type</th><th class="text-end">Balance</th></tr></thead>
                            <tbody>
                            @foreach (var a in _accounts)
                            {
                                <tr>
                                    <td>@a.Name</td>
                                    <td>@a.Institution</td>
                                    <td>@a.Type</td>
                                    <td class="text-end @(a.Balance < 0 ? "text-danger" : "")">@a.Balance.ToString("C")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool _loading = true;
    decimal _totalBalance;
    decimal _monthlySpending;
    decimal _monthlySubscriptions;
    int _activeAccountCount;
    List<Account> _accounts = new();
    List<Subscription> _upcomingSubscriptions = new();
    List<Document> _expiringDocuments = new();
    List<Expense> _recentExpenses = new();

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Now;
        _totalBalance = await AccountService.GetTotalBalanceAsync();
        _monthlySpending = await ExpenseService.GetMonthlyTotalAsync(now.Year, now.Month);
        _monthlySubscriptions = await SubscriptionService.GetEstimatedMonthlyTotalAsync();

        var accounts = await AccountService.GetActiveAccountsAsync();
        _accounts = accounts.ToList();
        _activeAccountCount = _accounts.Count;

        var upcoming = await SubscriptionService.GetUpcomingAsync(30);
        _upcomingSubscriptions = upcoming.ToList();

        var expiring = await DocumentService.GetExpiringSoonAsync(30);
        _expiringDocuments = expiring.ToList();

        var allExpenses = await ExpenseService.GetByDateRangeAsync(now.AddDays(-30), now);
        _recentExpenses = allExpenses.Take(10).ToList();

        _loading = false;
    }
}
