@page "/accounts"
@using FinanceTracker.Core.Models
@using FinanceTracker.Core.Services
@inject AccountService AccountService
@rendermode InteractiveServer

<PageTitle>Accounts - Finance Tracker</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Accounts</h1>
    <button class="btn btn-primary" @onclick="() => ShowForm(null)">+ Add Account</button>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-header">@(_editing?.Id > 0 ? "Edit Account" : "New Account")</div>
        <div class="card-body">
            <EditForm Model="_editing" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_editing!.Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Institution</label>
                        <InputText class="form-control" @bind-Value="_editing.Institution" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Type</label>
                        <InputSelect class="form-select" @bind-Value="_editing.Type">
                            @foreach (var t in Enum.GetValues<AccountType>())
                            {
                                <option value="@t">@t</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Balance</label>
                        <InputNumber class="form-control" @bind-Value="_editing.Balance" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Notes</label>
                        <InputText class="form-control" @bind-Value="_editing.Notes" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success me-2">Save</button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th><th>Institution</th><th>Type</th>
            <th class="text-end">Balance</th><th>Status</th><th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var a in _accounts)
    {
        <tr>
            <td>@a.Name</td>
            <td>@a.Institution</td>
            <td>@a.Type</td>
            <td class="text-end @(a.Balance < 0 ? "text-danger" : "")">@a.Balance.ToString("C")</td>
            <td><span class="badge @(a.IsActive ? "bg-success" : "bg-secondary")">@(a.IsActive ? "Active" : "Inactive")</span></td>
            <td>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowForm(a)">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(a.Id)">Delete</button>
            </td>
        </tr>
    }
    </tbody>
    <tfoot>
        <tr class="table-active fw-bold">
            <td colspan="3">Total</td>
            <td class="text-end">@_accounts.Where(a => a.IsActive).Sum(a => a.Balance).ToString("C")</td>
            <td colspan="2"></td>
        </tr>
    </tfoot>
</table>

@code {
    List<Account> _accounts = new();
    Account? _editing;
    bool _showForm;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        var all = await AccountService.GetAllAccountsAsync();
        _accounts = all.ToList();
    }

    void ShowForm(Account? account)
    {
        _editing = account != null
            ? new Account { Id = account.Id, Name = account.Name, Institution = account.Institution, Type = account.Type, Balance = account.Balance, Notes = account.Notes, IsActive = account.IsActive }
            : new Account();
        _showForm = true;
    }

    void Cancel() { _showForm = false; _editing = null; }

    async Task SaveAsync()
    {
        if (_editing == null) return;
        if (_editing.Id > 0)
            await AccountService.UpdateAccountAsync(_editing);
        else
            await AccountService.AddAccountAsync(_editing);
        _showForm = false;
        await LoadAsync();
    }

    async Task DeleteAsync(int id)
    {
        await AccountService.DeleteAccountAsync(id);
        await LoadAsync();
    }
}
