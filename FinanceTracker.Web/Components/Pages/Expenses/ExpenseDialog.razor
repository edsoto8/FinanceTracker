@inject IExpenseService ExpenseService
@inject ICategoryService CategoryService
@inject IAccountService AccountService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Model.Description" Label="Description" Required="true" MaxLength="200" />
        <MudNumericField @bind-Value="Model.Amount" Label="Amount" Format="N2" Min="0" Class="mt-3" />
        <MudSelect @bind-Value="Model.CategoryId" Label="Category" Class="mt-3">
            @foreach (var category in _categories)
            {
                <MudSelectItem T="int" Value="category.Id">@category.Name</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker @bind-Date="_transactionDate" Label="Transaction Date"
                       MaxDate="DateTime.Today" Class="mt-3" />
        <MudSelect T="int?" @bind-Value="Model.AccountId" Label="Account (optional)" Clearable="true" Class="mt-3">
            @foreach (var account in _accounts)
            {
                <MudSelectItem T="int?" Value="account.Id">@account.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="Model.PaymentMethod" Label="Payment Method" MaxLength="50" Class="mt-3" />
        <MudTextField @bind-Value="Model.Notes" Label="Notes" Lines="2" MaxLength="500" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Expense Model { get; set; } = new();

    private List<Category> _categories = new();
    private List<Account> _accounts = new();
    private DateTime? _transactionDate;

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetAllAsync()).ToList();
        _accounts = (await AccountService.GetActiveAccountsAsync()).ToList();
        _transactionDate = Model.TransactionDate == default ? DateTime.Today : Model.TransactionDate;
        if (Model.CategoryId == 0 && _categories.Count > 0)
        {
            Model.CategoryId = _categories[0].Id;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.Description))
        {
            Snackbar.Add("Description is required", Severity.Error);
            return;
        }

        if (Model.Amount <= 0)
        {
            Snackbar.Add("Amount must be greater than zero", Severity.Error);
            return;
        }

        Model.TransactionDate = _transactionDate ?? DateTime.Today;

        if (Model.Id == 0)
        {
            await ExpenseService.AddExpenseAsync(Model);
            Snackbar.Add("Expense added", Severity.Success);
        }
        else
        {
            await ExpenseService.UpdateExpenseAsync(Model);
            Snackbar.Add("Expense updated", Severity.Success);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
