@inject IDocumentService DocumentService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Model.Name" Label="Name" Required="true" MaxLength="100" />
        <MudSelect @bind-Value="Model.Type" Label="Type" Class="mt-3">
            @foreach (DocumentType type in Enum.GetValues<DocumentType>())
            {
                <MudSelectItem Value="type">@type</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker @bind-Date="_expirationDate" Label="Expiration Date" Class="mt-3" />
        <MudDatePicker @bind-Date="_reminderDate" Label="Reminder Date (optional)" Clearable="true" Class="mt-3" />
        <MudTextField @bind-Value="Model.Notes" Label="Notes" Lines="2" MaxLength="500" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Document Model { get; set; } = new();

    private DateTime? _expirationDate;
    private DateTime? _reminderDate;

    protected override void OnInitialized()
    {
        _expirationDate = Model.ExpirationDate == default ? DateTime.Today.AddYears(1) : Model.ExpirationDate;
        _reminderDate = Model.ReminderDate;
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            Snackbar.Add("Name is required", Severity.Error);
            return;
        }

        Model.ExpirationDate = _expirationDate ?? DateTime.Today;
        Model.ReminderDate = _reminderDate;

        if (Model.ReminderDate.HasValue && Model.ReminderDate.Value.Date >= Model.ExpirationDate.Date)
        {
            Snackbar.Add("Reminder date must be before the expiration date", Severity.Error);
            return;
        }

        if (Model.Id == 0)
        {
            await DocumentService.AddAsync(Model);
            Snackbar.Add("Document added", Severity.Success);
        }
        else
        {
            await DocumentService.UpdateAsync(Model);
            Snackbar.Add("Document updated", Severity.Success);
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
