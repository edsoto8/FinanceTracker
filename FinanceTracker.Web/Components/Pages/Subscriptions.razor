@page "/subscriptions"
@using FinanceTracker.Core.Models
@using FinanceTracker.Core.Services
@inject SubscriptionService SubscriptionService
@inject AccountService AccountService
@rendermode InteractiveServer

<PageTitle>Subscriptions - Finance Tracker</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Subscriptions</h1>
    <button class="btn btn-primary" @onclick="() => ShowForm(null)">+ Add Subscription</button>
</div>

<div class="mb-3">
    <span class="fw-bold">Estimated monthly total: </span>
    <span class="text-warning fw-bold">@_monthlyTotal.ToString("C")</span>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-header">@(_editing?.Id > 0 ? "Edit Subscription" : "New Subscription")</div>
        <div class="card-body">
            <EditForm Model="_editing" OnValidSubmit="SaveAsync">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_editing!.Name" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Cost</label>
                        <InputNumber class="form-control" @bind-Value="_editing.Cost" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Frequency</label>
                        <InputSelect class="form-select" @bind-Value="_editing.Frequency">
                            @foreach (var f in Enum.GetValues<BillingFrequency>())
                            {
                                <option value="@f">@f</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Next Billing</label>
                        <InputDate class="form-control" @bind-Value="_editing.NextBillingDate" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Category</label>
                        <InputText class="form-control" @bind-Value="_editing.Category" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Payment Account</label>
                        <InputSelect class="form-select" @bind-Value="_editing.PaymentAccountId">
                            <option value="">None</option>
                            @foreach (var a in _accounts)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Notes</label>
                        <InputText class="form-control" @bind-Value="_editing.Notes" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success me-2">Save</button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<table class="table table-hover">
    <thead>
        <tr><th>Name</th><th>Category</th><th>Frequency</th><th>Next Billing</th><th class="text-end">Cost</th><th class="text-end">Monthly</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var s in _subscriptions)
    {
        <tr>
            <td>@s.Name</td>
            <td>@s.Category</td>
            <td>@s.Frequency</td>
            <td class="@(s.NextBillingDate <= DateTime.Now.AddDays(7) ? "text-warning fw-bold" : "")">
                @s.NextBillingDate.ToString("MMM d, yyyy")
            </td>
            <td class="text-end">@s.Cost.ToString("C")</td>
            <td class="text-end">@s.MonthlyCost.ToString("C")</td>
            <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span></td>
            <td>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowForm(s)">Edit</button>
                @if (s.IsActive)
                {
                    <button class="btn btn-sm btn-outline-warning" @onclick="() => DeactivateAsync(s.Id)">Deactivate</button>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    List<Subscription> _subscriptions = new();
    List<Account> _accounts = new();
    Subscription? _editing;
    bool _showForm;
    decimal _monthlyTotal;

    protected override async Task OnInitializedAsync()
    {
        var accts = await AccountService.GetActiveAccountsAsync();
        _accounts = accts.ToList();
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        var all = await SubscriptionService.GetActiveAsync();
        _subscriptions = all.ToList();
        _monthlyTotal = await SubscriptionService.GetEstimatedMonthlyTotalAsync();
    }

    void ShowForm(Subscription? sub)
    {
        _editing = sub != null
            ? new Subscription { Id = sub.Id, Name = sub.Name, Cost = sub.Cost, Frequency = sub.Frequency, NextBillingDate = sub.NextBillingDate, Category = sub.Category, PaymentAccountId = sub.PaymentAccountId, IsActive = sub.IsActive, Notes = sub.Notes }
            : new Subscription { NextBillingDate = DateTime.Today.AddMonths(1), IsActive = true };
        _showForm = true;
    }

    void Cancel() { _showForm = false; _editing = null; }

    async Task SaveAsync()
    {
        if (_editing == null) return;
        if (_editing.Id > 0)
            await SubscriptionService.UpdateSubscriptionAsync(_editing);
        else
            await SubscriptionService.AddSubscriptionAsync(_editing);
        _showForm = false;
        await LoadAsync();
    }

    async Task DeactivateAsync(int id)
    {
        await SubscriptionService.DeactivateAsync(id);
        await LoadAsync();
    }
}
