@page "/expenses"
@using FinanceTracker.Core.Models
@using FinanceTracker.Core.Services
@inject ExpenseService ExpenseService
@inject AccountService AccountService
@inject ICategoryRepository CategoryRepository
@using FinanceTracker.Core.Interfaces
@rendermode InteractiveServer

<PageTitle>Expenses - Finance Tracker</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Expenses</h1>
    <button class="btn btn-primary" @onclick="() => ShowForm(null)">+ Add Expense</button>
</div>

<div class="row g-2 mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" class="form-control" @bind="_from" />
    </div>
    <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" class="form-control" @bind="_to" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" @onclick="LoadAsync">Filter</button>
    </div>
    <div class="col-auto ms-auto fw-bold">
        Total: @_expenses.Sum(e => e.Amount).ToString("C")
    </div>
</div>

@if (_showForm)
{
    <div class="card mb-4">
        <div class="card-header">@(_editing?.Id > 0 ? "Edit Expense" : "New Expense")</div>
        <div class="card-body">
            <EditForm Model="_editing" OnValidSubmit="SaveAsync">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Description</label>
                        <InputText class="form-control" @bind-Value="_editing!.Description" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Amount</label>
                        <InputNumber class="form-control" @bind-Value="_editing.Amount" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Date</label>
                        <InputDate class="form-control" @bind-Value="_editing.TransactionDate" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Category</label>
                        <InputSelect class="form-select" @bind-Value="_editing.Category">
                            @foreach (var c in _categories)
                            {
                                <option value="@c.Name">@c.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Account</label>
                        <InputSelect class="form-select" @bind-Value="_editing.AccountId">
                            @foreach (var a in _accounts)
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Payment Method</label>
                        <InputText class="form-control" @bind-Value="_editing.PaymentMethod" />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Notes</label>
                        <InputText class="form-control" @bind-Value="_editing.Notes" />
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-success me-2">Save</button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

<table class="table table-hover">
    <thead>
        <tr><th>Date</th><th>Description</th><th>Category</th><th>Payment</th><th class="text-end">Amount</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var e in _expenses)
    {
        <tr>
            <td>@e.TransactionDate.ToString("MMM d, yyyy")</td>
            <td>@e.Description</td>
            <td>@e.Category</td>
            <td>@e.PaymentMethod</td>
            <td class="text-end">@e.Amount.ToString("C")</td>
            <td>
                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowForm(e)">Edit</button>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(e.Id)">Delete</button>
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    List<Expense> _expenses = new();
    List<Account> _accounts = new();
    List<Category> _categories = new();
    Expense? _editing;
    bool _showForm;
    DateTime _from = DateTime.Now.AddMonths(-1);
    DateTime _to = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        var accts = await AccountService.GetActiveAccountsAsync();
        _accounts = accts.ToList();
        var cats = await CategoryRepository.GetAllAsync();
        _categories = cats.ToList();
        await LoadAsync();
    }

    async Task LoadAsync()
    {
        var results = await ExpenseService.GetByDateRangeAsync(_from, _to);
        _expenses = results.ToList();
    }

    void ShowForm(Expense? expense)
    {
        _editing = expense != null
            ? new Expense { Id = expense.Id, AccountId = expense.AccountId, Category = expense.Category, Description = expense.Description, Amount = expense.Amount, TransactionDate = expense.TransactionDate, PaymentMethod = expense.PaymentMethod, Notes = expense.Notes }
            : new Expense { TransactionDate = DateTime.Today, AccountId = _accounts.FirstOrDefault()?.Id ?? 0, Category = _categories.FirstOrDefault()?.Name ?? "" };
        _showForm = true;
    }

    void Cancel() { _showForm = false; _editing = null; }

    async Task SaveAsync()
    {
        if (_editing == null) return;
        if (_editing.Id > 0)
            await ExpenseService.UpdateExpenseAsync(_editing);
        else
            await ExpenseService.AddExpenseAsync(_editing);
        _showForm = false;
        await LoadAsync();
    }

    async Task DeleteAsync(int id)
    {
        await ExpenseService.DeleteExpenseAsync(id);
        await LoadAsync();
    }
}
