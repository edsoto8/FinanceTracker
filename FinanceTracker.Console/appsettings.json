{
  "Database": {
    "Path": "financetracker.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/financetracker-console-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
